# Copy to .env and fill in. Used by docker-compose.
# A long random shared secret; the name.ai app sends it as X-API-Key.
EMBED_SERVICE_API_KEY=change-me-to-a-long-random-secret

# Override models only if you know what you're doing — EMBED_MODEL must match the
# one that built the existing corpus (all-MiniLM-L6-v2) or vectors won't be comparable.
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANK_MODEL=BAAI/bge-reranker-base

EMBED_NORMALIZE=false
RERANK_SIGMOID=true
OMP_NUM_THREADS=4
