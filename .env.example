# ─────────────────────────────────────────────────────────────────────────────
# nameai-embed-service — environment variables
# Copy this file to .env and fill in your values.
# All vars have working defaults; only API_KEY is required in production.
# ─────────────────────────────────────────────────────────────────────────────

# ── Auth ──────────────────────────────────────────────────────────────────────
# Shared secret. Callers must send header: X-API-Key: <this value>
# Generate a strong random key: openssl rand -hex 32
EMBED_SERVICE_API_KEY=change-me-to-a-long-random-secret

# ── Embedding model ───────────────────────────────────────────────────────────
# IMPORTANT: This must match the model that built the domain_embeddings corpus.
# Changing it means all stored vectors are incompatible — requires a full re-embed.
# Default: all-MiniLM-L6-v2 (384-dim, fast CPU inference)
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Embedding output dimension — must match the model above.
EMBED_DIM=384

# Normalize embeddings to unit length before returning (true/false).
# Keep false to mirror the HuggingFace feature-extraction API output.
EMBED_NORMALIZE=false

# Max texts per /embed batch request.
MAX_EMBED_BATCH=256

# Inference batch size (how many texts the model processes at once internally).
EMBED_BATCH_SIZE=64

# ── Reranking model ───────────────────────────────────────────────────────────
# Cross-encoder model for /rerank. Swap without re-embedding the corpus.
#
# Recommended options (all CPU-compatible, self-hosted from HuggingFace):
#   BAAI/bge-reranker-v2-m3          — best speed/quality on CPU (recommended)
#   BAAI/bge-reranker-base            — lighter, current default
#   cross-encoder/ms-marco-MiniLM-L-12-v2 — alternative, trained on MS MARCO
#   jinaai/jina-reranker-v2-base-multilingual — fast, multilingual
#   Qwen3-Reranker-4B                 — best quality but needs GPU (skip on CPU)
#
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# Apply sigmoid to raw logits so scores are 0–1 (matches HuggingFace text-ranking output).
# Keep true so the name.ai relevance floor (ABS_FLOOR=0.35) works correctly.
RERANK_SIGMOID=true

# Max tokens per (query, text) pair fed to the reranker.
RERANK_MAX_LENGTH=512

# Max candidates per /rerank request.
MAX_RERANK_DOCS=100

# Reranker inference batch size.
RERANK_BATCH_SIZE=32

# ── CPU performance ───────────────────────────────────────────────────────────
# Number of CPU threads PyTorch uses for inference. Match to your vCPU count.
OMP_NUM_THREADS=4
